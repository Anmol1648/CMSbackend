generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  first_name    String
  last_name     String
  is_active     Boolean  @default(true)
  mfa_enabled   Boolean  @default(false)
  mfa_secret    String?
  tenant_id     String
  
  // Audit fields
  created_by    String?
  updated_by    String?

  // Relations
  profile       UserProfile?
  userRoles     UserRole[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@map("users")
}

model UserProfile {
  id            String    @id @default(uuid())
  user_id       String    @unique
  user          User      @relation(fields: [user_id], references: [id], onDelete: Cascade)
  
  phone         String?
  avatar_url    String?
  gender        String?
  date_of_birth DateTime? @db.Date
  address       String?
  city          String?
  state         String?
  country       String?
  pincode       String?
  
  created_by    String?
  updated_by    String?

  createdAt     DateTime  @default(now())

  updatedAt     DateTime  @updatedAt

  @@map("user_profiles")
}

model RefreshToken {
  token      String   @id
  user_id    String
  expires_at DateTime
  revoked    Boolean  @default(false)
  
  createdAt  DateTime @default(now())

  @@map("refresh_tokens")
}

model AuditLog {
  id          String   @id @default(uuid())
  table_name  String
  record_id   String
  operation   String   
  old_values  Json?
  new_values  Json?
  user_id     String   
  timestamp   DateTime @default(now())

  @@map("audit_logs")
}

model PasswordResetToken {
  id         String   @id @default(uuid())
  user_id    String
  otp_hash   String
  expires_at DateTime
  used       Boolean  @default(false)
  createdAt  DateTime @default(now())

  @@map("password_reset_tokens")
}

// ─── RBAC Models ──────────────────────────────────────────────────────────────

model Role {
  id             String    @id @default(uuid())
  name           String
  slug           String
  description    String?
  scope          String    @default("tenant") // global | tenant | department | self
  parent_role_id String?
  is_system      Boolean   @default(false)
  tenant_id      String
  created_by     String?
  updated_by     String?
  deleted_at     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  parent              Role?             @relation("RoleHierarchy", fields: [parent_role_id], references: [id])
  children            Role[]            @relation("RoleHierarchy")
  userRoles           UserRole[]
  rolePermissions     RolePermission[]
  roleMenus           RoleMenu[]
  fieldPermissions    FieldPermission[]
  roleWidgetMappings  RoleWidgetMapping[]

  @@unique([slug, tenant_id])
  @@index([tenant_id])
  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid())
  resource    String   // e.g., 'student', 'course', 'user'
  action      String   // create | read | update | delete | approve | export
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]

  @@unique([resource, action])
  @@map("permissions")
}

model RolePermission {
  id            String  @id @default(uuid())
  role_id       String
  permission_id String
  condition     Json?   // e.g., { "own_data": true, "own_department": true }

  role       Role       @relation(fields: [role_id], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permission_id], references: [id], onDelete: Cascade)

  @@unique([role_id, permission_id])
  @@map("role_permissions")
}

model UserRole {
  id        String   @id @default(uuid())
  user_id   String
  role_id   String
  tenant_id String
  createdAt DateTime @default(now())

  user User @relation(fields: [user_id], references: [id], onDelete: Cascade)
  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([user_id, role_id, tenant_id])
  @@index([tenant_id])
  @@index([user_id])
  @@map("user_roles")
}

model Menu {
  id         String   @id @default(uuid())
  label      String
  icon       String?
  route      String?
  module     String?
  is_active  Boolean  @default(true)
  parent_id  String?
  sort_order Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  parent    Menu?      @relation("MenuTree", fields: [parent_id], references: [id])
  children  Menu[]     @relation("MenuTree")
  roleMenus RoleMenu[]

  @@map("menus")
}

model RoleMenu {
  id      String  @id @default(uuid())
  role_id String
  menu_id String
  visible Boolean @default(true)

  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)
  menu Menu @relation(fields: [menu_id], references: [id], onDelete: Cascade)

  @@unique([role_id, menu_id])
  @@map("role_menus")
}

model FieldPermission {
  id         String  @id @default(uuid())
  role_id    String
  model_name String
  field_name String
  can_read   Boolean @default(true)
  can_write  Boolean @default(true)

  role Role @relation(fields: [role_id], references: [id], onDelete: Cascade)

  @@unique([role_id, model_name, field_name])
  @@map("field_permissions")
}

// ─── Dashboard Widget Models ──────────────────────────────────────────────────

model Widget {
  id             String   @id @default(uuid())
  title          String
  widget_type    String   // stat | chart | table | calendar | feed
  sub_type       String?  // bar | line | pie | donut | stat_card | audit_log | user_list
  config         Json?    // chart colors, axes config, thresholds, etc.
  query          String   @db.Text  // raw SQL for data-fetching
  display_name   String?
  customization  Json?    // icon, color, border-radius, custom CSS class
  range_enabled  Boolean  @default(false)
  is_active      Boolean  @default(true)
  created_by     String?
  updated_by     String?
  created_on     DateTime @default(now())
  updated_on     DateTime @updatedAt

  roleMappings   RoleWidgetMapping[]

  @@map("widgets")
}

model RoleWidgetMapping {
  id             String   @id @default(uuid())
  role_id        String
  widget_id      String
  enabled        Boolean  @default(true)
  display_order  Int      @default(0)
  height         Int      @default(1)  // grid units
  width          Int      @default(1)  // grid units (1=quarter, 2=half, 4=full)
  created_by     String?
  updated_by     String?
  created_on     DateTime @default(now())
  updated_on     DateTime @updatedAt

  role           Role     @relation(fields: [role_id], references: [id], onDelete: Cascade)
  widget         Widget   @relation(fields: [widget_id], references: [id], onDelete: Cascade)

  @@unique([role_id, widget_id])
  @@index([role_id])
  @@map("role_widget_mapping")
}


