PORT=3000

# RS256 public key (paste full key, use \n for line breaks in single-line format)
JWT_PUBLIC_KEY="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# Shared secret between gateway and services to reject direct calls
INTERNAL_SECRET=your_internal_secret_here

# Downstream service URLs
AUTH_SERVICE_URL=http://localhost:4001
STUDENT_SERVICE_URL=http://localhost:4002
RBAC_SERVICE_URL=http://localhost:4003
